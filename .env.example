# ===============================================
# Water Tank Backend - Environment Variables
# ===============================================
# Copy to .env and fill with your values
# Required for Render deployment

# ===============================================
# PostgreSQL Database Configuration
# ===============================================
DB_HOST=your-database-host.com
DB_PORT=5432
DB_NAME=water_tank_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_SSLMODE=require

# ===============================================
# ThingSpeak Integration (Optional)
# ===============================================
THINGSPEAK_API_KEY=your_thingspeak_write_api_key
THINGSPEAK_CHANNEL=your_channel_id_number

